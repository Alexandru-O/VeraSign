# Copy this file to .env and adjust as needed.
# `.env` is gitignored — never commit real secrets.

# SQL Server SA password (must satisfy SQL Server complexity: upper+lower+digit/symbol, >=8 chars).
MSSQL_SA_PASSWORD=ChangeMe!DemoPass123

# Symmetric key for the API's JWT bearer signing. Must be >=32 chars or JWT auth is silently disabled.
JWT_SIGNING_KEY=replace-this-with-32-plus-chars-of-entropy
