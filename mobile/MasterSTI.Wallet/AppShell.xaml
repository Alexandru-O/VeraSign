<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:pages="clr-namespace:MasterSTI.Wallet.Pages"
       x:Class="MasterSTI.Wallet.AppShell"
       Shell.FlyoutBehavior="Disabled"
       Shell.NavBarIsVisible="False"
       Shell.TabBarIsVisible="False"
       BackgroundColor="{StaticResource Bg}">

    <!--
        Routes are registered in code-behind. The default landing is the
        Onboarding page; AppShell.OnAppearing decides whether to skip ahead
        to the InboxPage if the wallet is already enrolled.
    -->
    <ShellContent x:Name="MainContent"
                  ContentTemplate="{DataTemplate pages:OnboardingPage}"
                  Route="onboarding" />

</Shell>
