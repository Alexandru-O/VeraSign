<?xml version="1.0" encoding="utf-8" ?>
<!--
    PillView v2 — pill-shaped status tag (port of prototype Brand.jsx Pill).
    Tone: neutral | success | warning | danger | info.
    Optional dot or icon to the left of the label.
-->
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:MasterSTI.Wallet.Controls"
             x:Class="MasterSTI.Wallet.Controls.PillView">

    <Border x:Name="PillBorder"
            BackgroundColor="{AppThemeBinding Light={StaticResource BgSunkenLight}, Dark={StaticResource BgSunkenDark}}"
            StrokeThickness="0"
            Padding="10,3"
            HorizontalOptions="Start"
            VerticalOptions="Center"
            StrokeShape="RoundRectangle 999">
        <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
            <controls:IconView x:Name="PillIcon"
                               IsVisible="False"
                               Size="12" />
            <Ellipse x:Name="PillDot"
                     WidthRequest="6"
                     HeightRequest="6"
                     IsVisible="False"
                     VerticalOptions="Center" />
            <Label x:Name="PillLabel"
                   Text="Pill"
                   FontSize="12"
                   FontFamily="{StaticResource FontSansMedium}"
                   VerticalTextAlignment="Center" />
        </HorizontalStackLayout>
    </Border>

</ContentView>
