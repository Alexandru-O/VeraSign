<?xml version="1.0" encoding="utf-8" ?>
<!--
    QRView v2 — QRCoder PngByteQRCode rendered into an Image element
    (per CLAUDE.md QR gotcha: do NOT switch to SVG). Outer Border carries
    the v2 token-driven surface treatment.
-->
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MasterSTI.Wallet.Controls.QRView">

    <Border BackgroundColor="{AppThemeBinding Light={StaticResource BgElevLight}, Dark={StaticResource BgElevDark}}"
            Stroke="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}"
            StrokeThickness="1"
            Padding="12"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            StrokeShape="RoundRectangle 8">
        <Image x:Name="QrImage"
               Aspect="AspectFit"
               BackgroundColor="White"
               WidthRequest="180"
               HeightRequest="180" />
    </Border>

</ContentView>
