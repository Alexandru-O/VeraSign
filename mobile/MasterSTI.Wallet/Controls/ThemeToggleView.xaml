<?xml version="1.0" encoding="utf-8" ?>
<!--
    ThemeToggleView v2 — 40x40 tap target with sun/moon icon.
    Tap calls App.ToggleTheme(), which persists the choice via Preferences.
    Watches Application.Current.RequestedThemeChanged to flip its glyph.
-->
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:MasterSTI.Wallet.Controls"
             x:Class="MasterSTI.Wallet.Controls.ThemeToggleView">

    <Border x:Name="ToggleBorder"
            BackgroundColor="{AppThemeBinding Light={StaticResource BgElevLight}, Dark={StaticResource BgElevDark}}"
            Stroke="{AppThemeBinding Light={StaticResource BorderLight}, Dark={StaticResource BorderDark}}"
            StrokeThickness="1"
            WidthRequest="40"
            HeightRequest="40"
            StrokeShape="RoundRectangle 8"
            HorizontalOptions="Start">
        <Border.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnTapped" />
        </Border.GestureRecognizers>
        <controls:IconView x:Name="Glyph"
                           Name="moon"
                           Size="16"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
    </Border>

</ContentView>
