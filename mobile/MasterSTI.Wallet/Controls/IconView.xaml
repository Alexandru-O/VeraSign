<?xml version="1.0" encoding="utf-8" ?>
<!--
    IconView v2 — Lucide-style stroke icon (1.6-stroke), rendered via
    Microsoft.Maui.Controls.Shapes.Path. Set Name to one of the keys defined
    in IconView.xaml.cs Paths (mirrors prototype/components/Brand.jsx Icon set).
    Theme-aware via AppThemeBinding (use TintColor to override).
-->
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
             x:Class="MasterSTI.Wallet.Controls.IconView">

    <shapes:Path x:Name="IconPath"
                 Stroke="{AppThemeBinding Light={StaticResource FgLight}, Dark={StaticResource FgDark}}"
                 StrokeThickness="1.6"
                 StrokeLineCap="Round"
                 StrokeLineJoin="Round"
                 Fill="Transparent"
                 Aspect="Uniform"
                 HeightRequest="20"
                 WidthRequest="20" />

</ContentView>
