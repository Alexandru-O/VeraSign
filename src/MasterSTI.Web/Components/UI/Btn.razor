@* VeraSign primary/secondary/ghost/danger button.
   Mirrors prototype/components/Brand.jsx Btn. *@

<button type="@Type"
        class="vs-btn vs-btn--@Variant vs-btn--@Size @AdditionalClass"
        disabled="@(Disabled || Loading)"
        @onclick="OnClick"
        style="@(Full ? "width:100%;" : null)">
    @if (Loading)
    {
        <span class="vs-btn__spinner" aria-hidden="true"></span>
    }
    else if (!string.IsNullOrEmpty(Icon))
    {
        <Icon Name="@Icon" Size="@(Size == "sm" ? 14 : 16)"/>
    }

    @if (ChildContent is not null)
    {
        <span class="vs-btn__label">@ChildContent</span>
    }

    @if (!Loading && !string.IsNullOrEmpty(IconRight))
    {
        <Icon Name="@IconRight" Size="@(Size == "sm" ? 14 : 16)"/>
    }
</button>

@code {
    /// <summary>"primary" | "secondary" | "ghost" | "danger" | "primaryDark" | "gold".</summary>
    [Parameter] public string Variant { get; set; } = "primary";

    /// <summary>"sm" | "md" | "lg".</summary>
    [Parameter] public string Size { get; set; } = "md";

    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool Loading { get; set; }
    [Parameter] public bool Full { get; set; }
    [Parameter] public string Type { get; set; } = "button";
    [Parameter] public string? Icon { get; set; }
    [Parameter] public string? IconRight { get; set; }
    [Parameter] public string? AdditionalClass { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }
}
