@* PhoneLineArt — line-art phone illustration used in Landing's "Pentru cetățeni" section.
   Direct port of Landing.jsx PhoneLineArt (lines 233-289). *@

<svg width="130" height="260" viewBox="0 0 130 260">
    <rect x="5" y="5" width="120" height="250" rx="18" fill="#fff" stroke="#0F3E93" stroke-width="2"/>
    <rect x="45" y="3" width="40" height="8" rx="4" fill="#0F3E93"/>

    @if (Variant == "dashboard")
    {
        <rect x="15" y="25" width="100" height="20" rx="10" fill="#fff" stroke="#0F3E93" stroke-width="1.2"/>
        <circle cx="25" cy="35" r="4" fill="#F8CF3F"/>
        <svg:text x="35" y="39" font-size="9" fill="#0F3E93" font-family="Inter" font-weight="600">Alex M.</svg:text>

        <circle cx="65" cy="120" r="40" fill="none" stroke="#0F3E93" stroke-width="3"/>
        <path d="M 65 80 A 40 40 0 0 1 95 110" stroke="#CAD7ED" stroke-width="3" fill="none"/>
        <svg:text x="65" y="125" text-anchor="middle" font-size="11" fill="#020E26" font-family="Inter" font-weight="700">AD45HG</svg:text>

        <rect x="30" y="180" width="70" height="22" rx="11" fill="#0F3E93"/>
        <svg:text x="65" y="195" text-anchor="middle" font-size="9" fill="#fff" font-family="Inter" font-weight="600">Folosește cod</svg:text>

        @foreach (var (x, i) in new[] { (20,0), (50,1), (80,2), (110,3) })
        {
            <rect x="@(x - 7)" y="220" width="14" height="14" rx="2"
                  fill="@(i == 0 ? "#0F3E93" : "none")" stroke="#0F3E93" stroke-width="1.2"/>
        }
    }
    else if (Variant == "grid")
    {
        <rect x="15" y="25" width="100" height="20" rx="10" fill="#fff" stroke="#0F3E93" stroke-width="1.2"/>
        <svg:text x="25" y="39" font-size="9" fill="#0F3E93" font-family="Inter">Caută furnizor</svg:text>
        <circle cx="105" cy="35" r="4" fill="none" stroke="#0F3E93" stroke-width="1.2"/>

        @for (var i = 0; i < 6; i++)
        {
            var x = 15 + (i % 2) * 52;
            var y = 60 + (i / 2) * 52;
            <g>
                <rect x="@x" y="@y" width="45" height="45" rx="6" fill="#fff" stroke="#0F3E93" stroke-width="1.5"/>
                @switch (i)
                {
                    case 0:
                        <path d="@($"M{x+15} {y+25} L{x+22} {y+18} L{x+30} {y+25} L{x+30} {y+35} L{x+15} {y+35} Z")"
                              fill="none" stroke="#0F3E93" stroke-width="1.5"/>
                        break;
                    case 1:
                        <path d="@($"M{x+22} {y+15} L{x+32} {y+19} V{y+28} C{x+32} {y+33} {x+27} {y+36} {x+22} {y+37} C{x+17} {y+36} {x+12} {y+33} {x+12} {y+28} V{y+19} Z")"
                              fill="none" stroke="#0F3E93" stroke-width="1.5"/>
                        break;
                    case 2:
                        <circle cx="@(x+22)" cy="@(y+22)" r="10" fill="none" stroke="#0F3E93" stroke-width="1.5"/>
                        break;
                    case 3:
                        <path d="@($"M{x+10} {y+25} Q{x+22} {y+15} {x+34} {y+25} M{x+22} {y+20} V{y+30}")"
                              fill="none" stroke="#0F3E93" stroke-width="1.5"/>
                        break;
                    case 4:
                        <rect x="@(x+12)" y="@(y+14)" width="18" height="20" rx="2" fill="none" stroke="#0F3E93" stroke-width="1.5"/>
                        <line x1="@(x+15)" y1="@(y+20)" x2="@(x+26)" y2="@(y+20)" stroke="#0F3E93" stroke-width="1.2"/>
                        <line x1="@(x+15)" y1="@(y+25)" x2="@(x+26)" y2="@(y+25)" stroke="#0F3E93" stroke-width="1.2"/>
                        break;
                    case 5:
                        <circle cx="@(x+22)" cy="@(y+22)" r="10" fill="none" stroke="#0F3E93" stroke-width="1.5"/>
                        <circle cx="@(x+19)" cy="@(y+20)" r="1" fill="#0F3E93"/>
                        <circle cx="@(x+25)" cy="@(y+20)" r="1" fill="#0F3E93"/>
                        <path d="@($"M{x+18} {y+26} Q{x+22} {y+29} {x+26} {y+26}")" stroke="#0F3E93" stroke-width="1.2" fill="none"/>
                        break;
                }
            </g>
        }

        @foreach (var (x, i) in new[] { (20,0), (50,1), (80,2), (110,3) })
        {
            <rect x="@(x - 7)" y="225" width="14" height="14" rx="2"
                  fill="@(i == 0 ? "#0F3E93" : "none")" stroke="#0F3E93" stroke-width="1.2"/>
        }
    }
</svg>

@code {
    /// <summary>"dashboard" | "grid".</summary>
    [Parameter] public string Variant { get; set; } = "dashboard";
}
