@* Lucide-style stroke icon set (24x24 viewBox, stroke=currentColor, fill=none).
   Paths copied 1:1 from prototype/components/Brand.jsx Icon (lines 37-78).
   Some legacy aliases kept (close=x, file=doc, pen, trash, share, bell, dot)
   so existing call-sites don't break. *@

<svg class="vs-icon vs-icon--@Name"
     width="@Size"
     height="@Size"
     viewBox="0 0 24 24"
     fill="none"
     stroke="@Color"
     stroke-width="@StrokeWidth.ToString(System.Globalization.CultureInfo.InvariantCulture)"
     stroke-linecap="round"
     stroke-linejoin="round"
     aria-hidden="true"
     focusable="false">
    @switch (Name)
    {
        case "arrow-right":
            <path d="M5 12h14"/>
            <path d="m12 5 7 7-7 7"/>
            break;
        case "arrow-up-right":
            <path d="M7 17 17 7"/>
            <path d="M7 7h10v10"/>
            break;
        case "arrow-left":
            <path d="M19 12H5"/>
            <path d="m12 19-7-7 7-7"/>
            break;
        case "check":
            <path d="M20 6 9 17l-5-5"/>
            break;
        case "check-circle":
            <circle cx="12" cy="12" r="10"/>
            <path d="m9 12 2 2 4-4"/>
            break;
        case "x":
        case "close":
            <path d="M18 6 6 18"/>
            <path d="m6 6 12 12"/>
            break;
        case "plus":
            <path d="M12 5v14"/>
            <path d="M5 12h14"/>
            break;
        case "minus":
            <path d="M5 12h14"/>
            break;
        case "chevron-down":
            <path d="m6 9 6 6 6-6"/>
            break;
        case "chevron-right":
            <path d="m9 6 6 6-6 6"/>
            break;
        case "chevron-left":
            <path d="m15 6-6 6 6 6"/>
            break;
        case "shield":
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/>
            break;
        case "shield-check":
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/>
            <path d="m9 12 2 2 4-4"/>
            break;
        case "doc":
        case "file":
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <path d="M14 2v6h6"/>
            break;
        case "file-signature":
        case "signature":
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <path d="M14 2v6h6"/>
            <path d="M8 18c2-2 4-2 6 0"/>
            <path d="M16 14h-1"/>
            break;
        case "fingerprint":
            <path d="M12 2a10 10 0 0 0-7.5 16.5"/>
            <path d="M12 6a6 6 0 0 0-6 6c0 3 1 5 1 5"/>
            <path d="M12 10a2 2 0 0 0-2 2c0 4-1 6-1 6"/>
            <path d="M16 18s1-3 1-6"/>
            <path d="M19 14a7 7 0 0 0-7-7"/>
            break;
        case "qr":
            <rect x="3" y="3" width="7" height="7"/>
            <rect x="14" y="3" width="7" height="7"/>
            <rect x="3" y="14" width="7" height="7"/>
            <path d="M14 14h3v3h-3z"/>
            <path d="M21 14v3"/>
            <path d="M14 21h7"/>
            break;
        case "wallet":
            <path d="M19 7V5a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-2"/>
            <path d="M21 9v6h-5a3 3 0 0 1 0-6z"/>
            break;
        case "lock":
            <rect x="3" y="11" width="18" height="11" rx="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            break;
        case "key":
            <circle cx="8" cy="15" r="4"/>
            <path d="M10.5 12.5 21 2"/>
            <path d="m17 6 3 3"/>
            <path d="m15 8 3 3"/>
            break;
        case "mail":
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="m22 7-10 6L2 7"/>
            break;
        case "upload":
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <path d="M7 10l5-5 5 5"/>
            <path d="M12 5v12"/>
            break;
        case "download":
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <path d="M7 14l5 5 5-5"/>
            <path d="M12 19V5"/>
            break;
        case "search":
            <circle cx="11" cy="11" r="8"/>
            <path d="m21 21-4.3-4.3"/>
            break;
        case "settings":
            <circle cx="12" cy="12" r="3"/>
            <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09a1.65 1.65 0 0 0-1-1.51 1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.6 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
            break;
        case "sun":
            <circle cx="12" cy="12" r="4"/>
            <path d="M12 2v2"/>
            <path d="M12 20v2"/>
            <path d="m4.93 4.93 1.41 1.41"/>
            <path d="m17.66 17.66 1.41 1.41"/>
            <path d="M2 12h2"/>
            <path d="M20 12h2"/>
            <path d="m6.34 17.66-1.41 1.41"/>
            <path d="m19.07 4.93-1.41 1.41"/>
            break;
        case "moon":
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79"/>
            break;
        case "inbox":
            <polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/>
            <path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11Z"/>
            break;
        case "clock":
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
            break;
        case "eye":
            <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/>
            <circle cx="12" cy="12" r="3"/>
            break;
        case "send":
            <path d="m22 2-7 20-4-9-9-4Z"/>
            <path d="M22 2 11 13"/>
            break;
        case "menu":
            <line x1="4" y1="6" x2="20" y2="6"/>
            <line x1="4" y1="12" x2="20" y2="12"/>
            <line x1="4" y1="18" x2="20" y2="18"/>
            break;
        case "globe":
            <circle cx="12" cy="12" r="10"/>
            <line x1="2" y1="12" x2="22" y2="12"/>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
            break;
        case "user":
            <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
            break;
        case "users":
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            break;
        case "history":
            <path d="M3 12a9 9 0 1 0 3-6.7L3 8"/>
            <path d="M3 3v5h5"/>
            <polyline points="12 7 12 12 15 14"/>
            break;
        case "folder":
            <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
            break;
        case "star":
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
            break;
        case "sparkle":
            <path d="M12 3v3"/>
            <path d="M12 18v3"/>
            <path d="M3 12h3"/>
            <path d="M18 12h3"/>
            <path d="m5.6 5.6 2.1 2.1"/>
            <path d="m16.3 16.3 2.1 2.1"/>
            <path d="m5.6 18.4 2.1-2.1"/>
            <path d="m16.3 7.7 2.1-2.1"/>
            break;
        case "eu":
            <circle cx="12" cy="12" r="10"/>
            <circle cx="12"   cy="6"    r="0.8" fill="@Color"/>
            <circle cx="12"   cy="18"   r="0.8" fill="@Color"/>
            <circle cx="6"    cy="12"   r="0.8" fill="@Color"/>
            <circle cx="18"   cy="12"   r="0.8" fill="@Color"/>
            <circle cx="7.7"  cy="7.7"  r="0.8" fill="@Color"/>
            <circle cx="16.3" cy="16.3" r="0.8" fill="@Color"/>
            <circle cx="7.7"  cy="16.3" r="0.8" fill="@Color"/>
            <circle cx="16.3" cy="7.7"  r="0.8" fill="@Color"/>
            break;

        @* Legacy aliases kept so existing call-sites don't 404. *@
        case "pen":
            <path d="M12 20h9"/>
            <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4Z"/>
            break;
        case "trash":
            <path d="M3 6h18"/>
            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/>
            <path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
            break;
        case "share":
            <circle cx="18" cy="5" r="3"/>
            <circle cx="6" cy="12" r="3"/>
            <circle cx="18" cy="19" r="3"/>
            <path d="m8.6 13.5 6.8 4M15.4 6.5l-6.8 4"/>
            break;
        case "bell":
            <path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/>
            <path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/>
            break;
        case "dot":
            <circle cx="12" cy="12" r="2.5" fill="@Color"/>
            break;
        case "grip":
            <circle cx="9" cy="6" r="1"/>
            <circle cx="9" cy="12" r="1"/>
            <circle cx="9" cy="18" r="1"/>
            <circle cx="15" cy="6" r="1"/>
            <circle cx="15" cy="12" r="1"/>
            <circle cx="15" cy="18" r="1"/>
            break;
        case "info":
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="16" x2="12" y2="12"/>
            <line x1="12" y1="8" x2="12.01" y2="8"/>
            break;

        default:
            <circle cx="12" cy="12" r="9"/>
            break;
    }
</svg>

@code {
    /// <summary>Lucide-style icon name (see switch above).</summary>
    [Parameter, EditorRequired] public string Name { get; set; } = "dot";

    /// <summary>Square render size in pixels.</summary>
    [Parameter] public double Size { get; set; } = 18;

    /// <summary>Stroke width — defaults to 1.6 per spec.</summary>
    [Parameter] public double StrokeWidth { get; set; } = 1.6;

    /// <summary>Stroke / fill color (defaults to currentColor so it inherits text color).</summary>
    [Parameter] public string Color { get; set; } = "currentColor";
}
